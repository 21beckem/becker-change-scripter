{
  "name": "becker-change-scripter",
  "displayName": "Becker Change Scripter",
  "description": "Custom editor for SQL change scripts with stored procedure management.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "sqlChangeScript.editor",
        "displayName": "Becker Change Scripter",
        "selector": [
          { "filenamePattern": "*.sql" }
        ],
        "priority": "default"
      }
    ]
  }
}
